# ==================== 基础配置 ====================

# API 认证密钥（必填，需与 flow2api 管理后台 "远程服务 API Key" 一致）
API_KEY=fcs_your_secret_key

# 服务端口
PORT=8060

# 最大并发浏览器数量（含预热和实时打码，每个约占 200-400MB 内存）
MAX_BROWSERS=10

# Session 超时清理时间（秒）
SESSION_TIMEOUT=1800

# 日志级别（DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# ==================== 代理配置（可选）====================

# BROWSER_PROXY_URL=http://user:pass@proxy.com:8080
# BROWSER_PROXY_URL=socks5://proxy.com:1080

# ==================== Token 预热池 ====================

# 是否启用预热池（启用后 /api/v1/solve 毫秒级返回）
POOL_ENABLED=true

# 目标维持的可用 token 数量（建议 ≥ 预期突发并发量）
POOL_SIZE=10

# Token 有效期（秒），reCAPTCHA token ~120s 有效，提前淘汰避免下发过期 token
TOKEN_TTL=90

# 持久化浏览器数量（常驻运行，不会反复启动/关闭）
POOL_WORKERS=3

# 每个持久化浏览器最大复用次数（超过后自动重启，防内存泄漏）
POOL_BROWSER_MAX_USES=50

# 水位检查间隔（秒）
POOL_CHECK_INTERVAL=5

# 每个 token 生产后冷却时间（秒），降低 CPU 峰值
POOL_COOLDOWN=1

# 预热打码使用的 project_id
POOL_DEFAULT_PROJECT=default_project

# ==================== 动态缩放配置 ====================

# 闲时最低池水位
POOL_SIZE_MIN=3

# 忙时最大池水位
POOL_SIZE_MAX=30

# 最少浏览器数
POOL_WORKERS_MIN=2

# 最多浏览器数
POOL_WORKERS_MAX=8

# 负载统计窗口（秒）
POOL_SCALE_WINDOW=60
